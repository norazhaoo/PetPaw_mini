<!-- pages/settings/settings.wxml -->
<wxs src="../../utils/icons.wxs" module="ic" />

<view class="app-container" style="max-width:700rpx;margin:0 auto;">
  <view class="card settings-card">
    <!-- Header -->
    <view class="settings-header">
      <image class="menu-icon" lazy-load src="{{ic.src('Settings')}}" mode="aspectFit" />
      <text class="h2">{{i18nData.settings}}</text>
    </view>

    <!-- Menu Items -->
    <view class="flex-col">
      <!-- Language -->
      <view class="menu-item" bindtap="toggleLangMenu">
        <view class="menu-item-left">
          <image class="menu-icon" lazy-load src="{{ic.src('Globe')}}" mode="aspectFit" />
          <text class="menu-label">{{i18nData.language}}</text>
        </view>
        <view class="menu-item-right">
          <text class="menu-value" style="font-weight:700;">{{currentLangLabel}}</text>
          <image class="menu-arrow" lazy-load src="{{ic.src('ChevronRight')}}" mode="aspectFit" />
        </view>
      </view>

      <!-- Language Grid -->
      <view wx:if="{{showLangMenu}}" class="lang-grid">
        <view wx:for="{{languages}}" wx:key="code"
          class="lang-btn {{currentLang === item.code ? 'lang-btn-active' : ''}}"
          bindtap="selectLanguage" data-code="{{item.code}}">
          <image wx:if="{{currentLang === item.code}}" class="icon-img" lazy-load style="width:32rpx;height:32rpx;" src="{{ic.src('Check')}}" mode="aspectFit" />
          {{item.label}}
        </view>
      </view>

      <!-- Help -->
      <view class="menu-item" bindtap="showHelp">
        <view class="menu-item-left">
          <image class="menu-icon" lazy-load src="{{ic.src('HelpCircle')}}" mode="aspectFit" />
          <text class="menu-label">{{i18nData.help}}</text>
        </view>
        <image class="menu-arrow" lazy-load src="{{ic.src('ChevronRight')}}" mode="aspectFit" />
      </view>

      <!-- About -->
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-item-left">
          <image class="menu-icon" lazy-load src="{{ic.src('Info')}}" mode="aspectFit" />
          <text class="menu-label">{{i18nData.about}}</text>
        </view>
        <image class="menu-arrow" lazy-load src="{{ic.src('ChevronRight')}}" mode="aspectFit" />
      </view>

      <!-- Clear Data -->
      <view class="clear-btn" bindtap="handleClearData">
        <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;" src="{{ic.src('Trash2')}}" mode="aspectFit" />
        <text style="font-weight:700;font-size:30rpx;color:#E74C3C;">{{i18nData.clear_data}}</text>
      </view>
    </view>
  </view>
</view>
