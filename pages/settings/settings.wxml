<!-- pages/settings/settings.wxml -->
<view class="app-container" style="max-width:700rpx;margin:0 auto;">
  <view class="card settings-card">
    <!-- Header -->
    <view class="settings-header">
      <icon name="Settings" size="48" color="#FEE140" />
      <text class="h2" style="margin:0;font-size:36rpx;">{{i18nData.settings}}</text>
    </view>

    <!-- Menu Items -->
    <view class="flex-col">
      <!-- Language -->
      <view class="menu-item" bindtap="toggleLangMenu">
        <view class="flex-row gap-md">
          <icon name="Globe" size="40" color="#8F8377" />
          <text class="menu-label">{{i18nData.language}}</text>
        </view>
        <view class="flex-row gap-md" style="color:var(--text-muted);">
          <text style="font-size:28rpx;font-weight:700;">{{currentLangLabel}}</text>
          <icon name="ChevronRight" size="36" color="#8F8377" />
        </view>
      </view>

      <!-- Language Grid -->
      <view wx:if="{{showLangMenu}}" class="lang-grid">
        <view wx:for="{{languages}}" wx:key="code"
          class="lang-btn {{currentLang === item.code ? 'lang-btn-active' : ''}}"
          bindtap="selectLanguage" data-code="{{item.code}}">
          <icon wx:if="{{currentLang === item.code}}" name="Check" size="32" color="#fff" />
          {{item.label}}
        </view>
      </view>

      <!-- Help -->
      <view class="menu-item" bindtap="showHelp">
        <view class="flex-row gap-md">
          <icon name="HelpCircle" size="40" color="#8F8377" />
          <text class="menu-label">{{i18nData.help}}</text>
        </view>
        <icon name="ChevronRight" size="36" color="#8F8377" />
      </view>

      <!-- About -->
      <view class="menu-item" bindtap="showAbout">
        <view class="flex-row gap-md">
          <icon name="Info" size="40" color="#8F8377" />
          <text class="menu-label">{{i18nData.about}}</text>
        </view>
        <icon name="ChevronRight" size="36" color="#8F8377" />
      </view>

      <!-- Clear Data -->
      <view class="clear-btn" bindtap="handleClearData">
        <icon name="Trash2" size="36" color="#E74C3C" />
        <text style="font-weight:700;font-size:30rpx;color:#E74C3C;">{{i18nData.clear_data}}</text>
      </view>
    </view>
  </view>
</view>
