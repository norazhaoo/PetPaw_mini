/* pages/settings/settings.wxss */

.settings-card {
  padding: 0;
  overflow: hidden;
}

.settings-header {
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 2rpx solid #F0EDE6;
  background: #FFFDF2;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 2rpx solid #F0EDE6;
  width: 100%;
  box-sizing: border-box;
}

/* For labels and icons on the left */
.menu-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

/* For values and arrows on the right */
.menu-item-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: var(--text-muted);
}

.menu-label {
  font-weight: 700;
  font-size: 30rpx;
  color: var(--text-main);
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
}

.menu-arrow {
  width: 36rpx;
  height: 36rpx;
}

.lang-grid {
  background: #FAF9F5;
  padding: 40rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  border-bottom: 2rpx solid #F0EDE6;
}

.lang-btn {
  background: var(--card-bg);
  color: var(--text-main);
  border: 4rpx solid #E0DACA;
  padding: 24rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.lang-btn-active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  box-shadow: var(--shadow-button);
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx;
  margin-top: 16rpx;
}
