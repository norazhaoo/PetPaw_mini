/* pages/pawfile/pawfile.wxss */

.form-header {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  margin-bottom: 48rpx;
}

.back-btn {
  position: absolute;
  left: 0;
  padding: 16rpx;
}

.avatar-upload-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.avatar-preview-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid var(--primary);
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-remove-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 52rpx;
  height: 52rpx;
  background: #E74C3C;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 4rpx 12rpx rgba(231,76,60,0.3);
  z-index: 10;
}

.avatar-placeholder {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: #F0EDE6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed var(--text-muted);
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  font-weight: 700;
  font-size: 28rpx;
}

.species-row {
  display: flex;
  gap: 16rpx;
}

.species-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--card-bg);
  border: 2rpx solid #E0DACA;
  color: var(--text-main);
  font-weight: 700;
  text-align: center;
  font-size: 28rpx;
}

.species-active {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}

.btn-row {
  display: flex;
  gap: 32rpx;
  margin-top: 64rpx;
}

/* Pet List Swipe */
.pet-swipe-item {
  width: 100%;
  height: 192rpx;
}

.swipe-area {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
}

.swipe-view {
  width: calc(100% + 240rpx); /* Combined width for card and buttons */
  height: 100%;
  display: flex;
}

.pet-card {
  width: calc(100% - 240rpx); /* Fills visible area (100% of swipe-area) */
  height: 100%;
  background: var(--card-bg);
  padding: 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.pet-card-add {
  width: 100%;
  height: 160rpx;
  background: transparent;
  border: 4rpx dashed var(--primary);
  box-shadow: none;
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 32rpx;
  box-sizing: border-box;
  border-radius: var(--radius-lg);
}

.swipe-buttons {
  width: 240rpx;
  height: 100%;
  display: flex;
  flex-shrink: 0;
}

.swipe-btn {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.edit-btn {
  background: transparent;
  color: var(--text-muted);
}

.delete-btn {
  background: transparent;
  color: #E74C3C;
}

.pet-avatar-add {
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--primary);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-avatar {
  width: 100%;
  height: 100%;
}

.pet-avatar-letter {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-main);
}

.pet-name {
  font-weight: 800;
  font-size: 36rpx;
  color: var(--text-main);
  display: block;
}

.pet-breed {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  display: block;
}

.pet-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pet-action-btn {
  background: var(--card-bg);
  border-radius: 50%;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
}

.delete-btn {
  background: #FDEBD0;
}

.add-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}
