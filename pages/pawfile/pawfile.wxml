<!-- pages/pawfile/pawfile.wxml -->
<wxs src="../../utils/icons.wxs" module="ic" />

<view class="app-container">
  <!-- 添加/编辑表单 -->
  <view wx:if="{{isAdding}}">
    <view class="form-header">
      <view class="back-btn" bindtap="resetForm">
        <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src('ChevronLeft')}}" mode="aspectFit" />
      </view>
      <text class="h2">{{editingPetId ? i18n.edit_pet : i18n.add_pet}}</text>
    </view>

    <view class="card">
      <!-- 头像上传 -->
      <view class="avatar-upload-wrap">
        <view wx:if="{{avatar}}" style="position: relative;">
          <view class="avatar-preview-wrap">
            <image class="avatar-preview" src="{{avatar}}" mode="aspectFill" />
          </view>
          <view class="avatar-remove-btn" bindtap="removeAvatar">×</view>
        </view>
        <view wx:else class="avatar-placeholder" bindtap="chooseAvatar">
          <image class="icon-img" lazy-load style="width:64rpx;height:64rpx;" src="{{ic.src('Camera')}}" mode="aspectFit" />
          <text class="text-muted" style="font-size:20rpx;margin-top:8rpx;">{{i18n.photo}}</text>
        </view>
      </view>

      <!-- Species -->
      <view class="form-group">
        <text class="form-label">{{i18n.species}} *</text>
        <view class="species-row">
          <view wx:for="{{speciesList}}" wx:key="*this"
            class="species-btn {{species === item ? 'species-active' : ''}}"
            bindtap="setSpecies" data-species="{{item}}">
            {{i18n[item]}}
          </view>
        </view>
      </view>

      <!-- Name -->
      <view class="form-group">
        <text class="form-label">{{i18n.name}} *</text>
        <input class="input-field" value="{{name}}" bindinput="onNameInput" />
      </view>

      <!-- Breed -->
      <view class="form-group">
        <text class="form-label">{{i18n.breed_optional}}</text>
        <input class="input-field" value="{{breed}}" bindinput="onBreedInput" />
      </view>

      <!-- Birthday -->
      <view class="form-group">
        <text class="form-label">{{i18n.birthday_optional}}</text>
        <picker mode="date" value="{{birthday}}" bindchange="onBirthdayChange">
          <view class="input-field">{{birthday || '----/--/--'}}</view>
        </picker>
      </view>

      <!-- Weight (only for new pets) -->
      <view class="form-group" wx:if="{{!editingPetId}}">
        <text class="form-label">{{i18n.weight_kg}} *</text>
        <input class="input-field" type="digit" value="{{initialWeight}}" bindinput="onWeightInput" />
      </view>

      <!-- Photo URL -->
      <view class="form-group">
        <text class="form-label">{{i18n.photo_url}}</text>
        <input class="input-field" value="{{avatar || ''}}" bindinput="onAvatarUrlInput" placeholder="https://..." />
      </view>

      <!-- Buttons -->
      <view class="btn-row">
        <button class="btn-secondary flex-1" bindtap="resetForm">{{i18n.cancel}}</button>
        <button class="btn-primary flex-1" bindtap="handleSave" disabled="{{!name}}">{{i18n.save}}</button>
      </view>
    </view>
  </view>

  <!-- 宠物列表 -->
  <view wx:else>
    <view class="text-center flex-col" style="align-items:center; margin-bottom:64rpx; gap:12rpx;">
      <image class="icon-img" lazy-load style="width:112rpx;height:112rpx; mix-blend-mode: multiply;" src="/static/icons/tab-pawfile-active.png" mode="aspectFit" />
      <text class="h1" style="font-size:72rpx; font-family: 'Arial Rounded MT Bold', 'Nunito', 'Varela Round', system-ui, sans-serif;">PetPaw</text>
      <text class="text-muted" style="display:block;margin-top:8rpx;">{{i18n.who_caring}}</text>
    </view>

    <view class="flex-col gap-md">
      <!-- 每个宠物 (带侧滑) -->
      <view wx:for="{{pets}}" wx:key="id" class="pet-swipe-item">
        <movable-area class="swipe-area">
          <movable-view class="swipe-view" direction="horizontal" out-of-bounds="true" x="{{item.swipeX || 0}}" inertia="true">
            <!-- 上层展示卡片 -->
            <view class="pet-card" bindtap="selectPet" data-id="{{item.id}}">
              <view class="pet-avatar-wrap">
                <image wx:if="{{item.avatar}}" class="pet-avatar" src="{{item.avatar}}" mode="aspectFill" />
                <text wx:else class="pet-avatar-letter">{{item.name[0]}}</text>
              </view>
              <view class="flex-1">
                <text class="pet-name">{{item.name}}</text>
                <text wx:if="{{item.breed}}" class="pet-breed">{{item.breed}}</text>
              </view>
              <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src('ChevronRight')}}" mode="aspectFit" />
            </view>
            <!-- 侧边操作按钮 -->
            <view class="swipe-buttons">
              <view class="swipe-btn edit-btn" catchtap="handleEditClick" data-id="{{item.id}}">
                <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;margin-bottom:4rpx;" src="{{ic.src('Pencil')}}" mode="aspectFit" />
                <text>{{i18n.edit}}</text>
              </view>
              <view class="swipe-btn delete-btn" catchtap="handleDeletePet" data-id="{{item.id}}" data-name="{{item.name}}">
                <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;margin-bottom:4rpx;" src="{{ic.src('Trash2')}}" mode="aspectFit" />
                <text>{{i18n.delete}}</text>
              </view>
            </view>
          </movable-view>
        </movable-area>
      </view>

      <!-- 添加按钮 -->
      <view class="pet-list-item" bindtap="startAdding">
        <view class="pet-card pet-card-add">
          <view class="pet-avatar-wrap pet-avatar-add">
            <image class="icon-img" lazy-load style="width:56rpx;height:56rpx;" src="{{ic.src('Plus')}}" mode="aspectFit" />
          </view>
          <view class="flex-1">
            <text class="pet-name" style="color:var(--text-muted);">{{i18n.add_pet}}</text>
          </view>
          <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src('ChevronRight')}}" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>
</view>
