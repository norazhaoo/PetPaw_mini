/* pages/stock/stock.wxss */

.stock-card {
  margin-bottom: 32rpx;
  position: relative;
}

.stock-card-add {
  background: transparent;
  border: 4rpx dashed var(--primary);
  box-shadow: none;
}

.add-card-inner {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.add-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stock-delete-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 2;
}

.amount-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F0EDE6;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
}

.amount-btn {
  background: var(--card-bg);
  border-radius: 50%;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
}

.amount-btn-plus {
  background: var(--primary);
}

.amount-display {
  display: flex;
  align-items: center;
  justify-content: center;
}

.amount-input {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-main);
  width: 180rpx;
  height: 80rpx;
  min-height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: transparent;
  border: none;
}

.unit-text {
  font-size: 32rpx;
  color: var(--text-muted);
  margin-left: 8rpx;
  font-weight: 700;
}

.preset-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.preset-btn {
  flex: 1;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E0DACA;
  background: transparent;
  font-weight: 700;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-main);
  min-width: 120rpx;
}

.preset-active {
  border: 4rpx solid var(--text-main);
  background: #fff;
}

.consumption-section {
  padding: 0 16rpx;
  margin-top: 24rpx;
}

.consumption-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F0EDE6;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
}

.consumption-text {
  font-size: 26rpx;
  color: var(--text-muted);
  white-space: nowrap;
}

.consumption-input {
  background: transparent;
  border-radius: 12rpx;
  height: 64rpx;
  font-weight: 800;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-main);
}

.input-picker-wrap {
  display: flex;
  align-items: center;
  background: transparent;
  border-radius: 12rpx;
  padding-right: 8rpx;
}

.picker-trigger {
  font-size: 20rpx;
  color: var(--text-muted);
  padding: 0 4rpx;
}

.interval-input {
  width: 90rpx;
  background: transparent !important;
  box-shadow: none !important;
}

.unit-picker-box {
  display: flex;
  align-items: center;
  background: transparent;
  border-radius: 12rpx;
  padding: 0 12rpx;
  height: 64rpx;
}

.amount-input {
  width: 90rpx;
}

.consumption-unit-badge {
  background: transparent;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: var(--text-main);
}

.add-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-pick-btn {
  background: transparent;
  border: 2rpx solid #E0DACA;
  border-radius: 24rpx;
  padding: 16rpx;
  flex-shrink: 0;
}

.icon-pick-active {
  border-color: transparent;
}

