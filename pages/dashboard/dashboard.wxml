<!-- pages/dashboard/dashboard.wxml -->
<wxs src="../../utils/icons.wxs" module="ic" />

<view class="app-container" wx:if="{{activePet}}">
  <!-- Header -->
  <view class="header-card">
    <image wx:if="{{activePet.avatar}}" class="header-avatar" src="{{activePet.avatar}}" mode="aspectFill" />
    <view wx:else class="header-avatar-placeholder">
      <text>{{activePet.species === 'dog' ? '🐶' : activePet.species === 'other' ? '🐾' : '🐱'}}</text>
    </view>
    <view class="flex-col">
      <text style="font-size:52rpx;font-weight:900;color:var(--text-main);letter-spacing:-1rpx;line-height:1.2;">{{activePet.name}}</text>
      <text style="font-size:26rpx;font-weight:700;color:var(--text-muted);">{{activePet.breed || (activePet.species === 'dog' ? i18n.dog : activePet.species === 'cat' ? i18n.cat : i18n.pawfile)}}</text>
    </view>
  </view>

  <!-- Stock Alert -->
  <view class="section-block">
    <text class="section-title">{{i18n.stock_alert}}</text>
    <scroll-view scroll-x="true" class="pill-scroll">
      <view class="pill-row">
        <view class="pill-item" wx:for="{{inventoryItems}}" wx:key="id">
          <view class="pill-icon-wrap" style="background:{{item.isLow ? '#FDEBD0' : item.color + '22'}};">
            <image class="icon-img" lazy-load style="width:56rpx;height:56rpx; opacity:0.65;" src="{{ic.src(item.iconName || 'Package')}}" mode="aspectFit" />
          </view>
          <text class="pill-value" style="color:{{item.isLow ? '#E74C3C' : 'var(--text-main)'}};">{{item.daysLeft}}{{i18n.d}}</text>
          <text class="pill-label">{{item.shortLabel}}</text>
        </view>
        <view class="pill-item-wrap" wx:for="{{stockActionItems}}" wx:key="actionKey">
          <view
            class="pill-item"
            bindtap="handleTrackAction"
            data-kind="{{item.actionKind}}"
            data-type="{{item.type}}"
            data-id="{{item.id}}"
            data-label="{{item.stockLabel}}"
            data-color="{{item.color}}"
            data-iconidx="{{item.iconIdx}}"
          >
            <view class="pill-icon-wrap" style="background:{{item.color}}22;">
              <image class="icon-img" lazy-load style="width:56rpx;height:56rpx;" src="{{ic.src(item.iconName)}}" mode="aspectFit" />
            </view>
            <text class="pill-value">{{item.lastActionText}}</text>
            <text class="pill-label">{{item.stockLabel}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Things to Track -->
  <view class="section-block">
    <view class="flex-row justify-between align-center" style="margin-bottom: 8rpx;">
      <text class="section-title">{{i18n.things_to_track}}</text>
      <text wx:if="{{isEditingActions}}" class="text-primary font-bold" style="font-size:24rpx;padding:8rpx 16rpx;" bindtap="stopEditActions">{{i18n.done || 'Done'}}</text>
    </view>
    <scroll-view scroll-x="{{!dragActionKey}}" class="pill-scroll">
      <view class="pill-row {{isEditingActions ? 'edit-mode' : ''}}">
        <!-- Track actions -->
        <view
          class="pill-item-wrap {{dragActionKey === item.actionKey ? 'dragging' : ''}}"
          wx:for="{{trackActions}}"
          wx:key="actionKey"
          data-action-key="{{item.actionKey}}"
          data-index="{{index}}"
          bindtouchstart="onTrackActionTouchStart"
          bindtouchmove="onTrackActionTouchMove"
          bindtouchend="onTrackActionTouchEnd"
          bindtouchcancel="onTrackActionTouchEnd"
        >
          <view
            class="pill-item {{item.hidden ? 'hidden-item' : ''}}"
            bindtap="handleTrackAction"
            bindlongpress="startEditActions"
            data-action-key="{{item.actionKey}}"
            data-index="{{index}}"
            data-kind="{{item.actionKind}}"
            data-type="{{item.type}}"
            data-id="{{item.id}}"
            data-label="{{item.actionKind === 'custom' ? item.label : (i18n[item.type] || item.type)}}"
            data-color="{{item.color}}"
            data-iconidx="{{item.iconIdx}}"
          >
            <view class="pill-icon-wrap" style="background:{{item.color}}22;">
              <image class="icon-img" lazy-load style="width:56rpx;height:56rpx;" src="{{ic.src(item.iconName)}}" mode="aspectFit" />
            </view>
            <text class="pill-label">{{item.actionKind === 'custom' ? item.label : (i18n[item.type] || item.type)}}</text>
          </view>
          <view
            wx:if="{{isEditingActions}}"
            class="pill-delete-btn {{item.hidden ? 'hidden-item' : ''}}"
            catchtap="hideTrackAction"
            data-kind="{{item.actionKind}}"
            data-type="{{item.type}}"
            data-id="{{item.id}}"
          >
             <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;" src="{{ic.src(item.actionKind === 'custom' ? 'XCircle' : (item.hidden ? 'Eye' : 'XCircle'))}}" mode="aspectFit" />
          </view>
        </view>

        <!-- Add custom -->
        <view class="pill-item" bindtap="openCustomModal">
          <view class="pill-icon-wrap" style="background:#F0EDE6;">
            <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src('Plus')}}" mode="aspectFit" />
          </view>
          <text class="pill-label" style="color:var(--text-muted);">{{i18n.custom}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- Feedback -->
    <text wx:if="{{feedback}}" class="feedback-text" style="margin-top:16rpx;color:{{feedbackColor || 'var(--success)'}};">{{feedback}}</text>
  </view>

  <!-- Calendar Card (延迟渲染) -->
  <view class="card" wx:if="{{ready}}">
    <view class="flex-between" style="margin-bottom:32rpx;">
      <view bindtap="prevMonth" style="padding:16rpx;">
        <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src('ChevronLeft')}}" mode="aspectFit" />
      </view>
      <view class="flex-row gap-md">
        <text class="h3" style="margin:0;">{{currentMonthLabel}}</text>
        <view class="today-btn" bindtap="goToday">{{i18n.today || 'Today'}}</view>
      </view>
      <view bindtap="nextMonth" style="padding:16rpx;">
        <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src('ChevronRight')}}" mode="aspectFit" />
      </view>
    </view>

    <!-- Weekday headers -->
    <view class="cal-grid cal-header">
      <text wx:for="{{weekdays}}" wx:key="*this" class="cal-weekday">{{item}}</text>
    </view>

    <!-- Days -->
    <view class="cal-grid" style="margin-top:16rpx;">
      <view wx:for="{{blanks}}" wx:key="*this" class="cal-cell"></view>
      <view wx:for="{{daysInMonth}}" wx:key="dateStr" class="cal-cell {{item.isSelected ? 'cal-selected' : ''}} {{item.isToday ? 'cal-today' : ''}}"
        bindtap="selectDate" data-date="{{item.dateStr}}">
        <text class="cal-day-num {{item.isToday ? 'cal-today-num' : ''}}">{{item.dayNum}}</text>
        <view class="cal-icons">
          <view wx:for="{{item.icons}}" wx:for-item="ic2" wx:key="name" class="cal-icon-dot" style="background:{{ic2.color}}22;">
            <image class="icon-img" lazy-load style="width:22rpx;height:22rpx;" src="{{ic.src(ic2.name)}}" mode="aspectFit" />
          </view>
        </view>
      </view>
    </view>

    <!-- Monthly Stats -->
    <view style="margin-top:40rpx;padding-top:32rpx;border-top:2rpx solid #F0EDE6; position:relative;">
      <view class="flex-row justify-between align-center" style="margin-bottom:24rpx;">
        <text style="font-size:26rpx;color:var(--text-muted);">{{i18n.monthly_stats}}</text>
        <view bindtap="exportReport" hover-class="opacity-half" style="display:flex;align-items:center;gap:8rpx;background:var(--primary);color:#4A403A;border-radius:32rpx;padding:12rpx 28rpx;box-shadow:var(--shadow-button);">
          <image class="icon-img" style="width:28rpx;height:28rpx;" src="{{ic.src('FileText')}}" mode="aspectFit" />
          <text style="font-size:26rpx;font-weight:800;">{{i18n.export_report || '导出报告'}}</text>
        </view>
      </view>
      <view class="flex-row flex-wrap gap-md" wx:if="{{monthlyStats.length > 0}}">
        <view wx:for="{{monthlyStats}}" wx:key="type" class="stat-badge">
          <view class="stat-icon-wrap" style="background:{{item.color}}22;">
            <image class="icon-img" lazy-load style="width:28rpx;height:28rpx;" src="{{ic.src(item.iconName)}}" mode="aspectFit" />
          </view>
          <text style="font-size:26rpx;font-weight:700;">x{{item.count}}</text>
        </view>
      </view>
      <text wx:else class="text-muted" style="font-size:24rpx;">{{i18n.no_activity}}</text>
    </view>
  </view>

  <!-- Weight History Chart (延迟渲染) -->
  <view class="card" wx:if="{{ready}}">
    <view class="flex-row gap-md" style="margin-bottom:16rpx;">
      <text class="h2" style="font-size:32rpx;margin:0;">{{i18n.weight_history}}</text>
      <image class="icon-img" lazy-load style="width:40rpx;height:40rpx;" src="{{ic.src('scale')}}" mode="aspectFit" />
    </view>
    <view style="height:360rpx;">
      <canvas wx:if="{{hasWeightData}}" type="2d" id="weightCanvas" style="width:100%;height:100%;" />
      <view wx:else class="flex-center" style="width:100%;height:100%;">
        <text class="text-muted" style="font-size:24rpx;">{{i18n.no_weight_history}}</text>
      </view>
    </view>
  </view>

  <!-- Selected Day Logs (延迟渲染) -->
  <view class="card" wx:if="{{ready}}">
    <text class="h2" style="font-size:32rpx;margin-bottom:16rpx;">{{listTitle}}</text>
    <view wx:if="{{combinedLogs.length === 0}}">
      <text class="text-muted" style="font-size:26rpx;">{{i18n.no_records_day}}</text>
    </view>
    <view class="flex-col gap-md" wx:else>
      <view wx:for="{{combinedLogs}}" wx:key="id" class="log-item">
        <view class="flex-row gap-md flex-1">
          <view class="log-icon-wrap" style="background:{{item.iconColor}}22;">
            <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src(item.iconName)}}" mode="aspectFit" />
          </view>
          <view class="flex-col">
            <text style="font-weight:700;font-size:26rpx;">{{item.label}}</text>
            <text class="text-muted" style="font-size:20rpx;">{{item.time}}</text>
          </view>
        </view>
        <view bindtap="deleteLog" data-id="{{item.id}}" data-typegroup="{{item.typeGroup}}">
          <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;" src="{{ic.src('XCircle')}}" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>

  <!-- Custom Event Modal -->
  <view wx:if="{{showCustomModal}}" class="modal-overlay" catchtap="closeCustomModal">
    <view class="modal-content card" catchtap="noop">
      <text class="h3">{{i18n.new_custom_event}}</text>
      <input class="input-field" placeholder="{{i18n.custom_event_placeholder}}" value="{{customName}}" bindinput="onCustomNameInput" />

      <text class="font-bold" style="margin-top:24rpx;font-size:28rpx;">{{i18n.select_icon}}</text>
      <scroll-view scroll-x="true" style="margin-top:16rpx;">
        <view class="flex-row gap-md">
          <view wx:for="{{customIconNames}}" wx:key="*this" wx:for-index="idx"
            class="icon-select-btn {{customIconIdx === idx ? 'icon-select-active' : ''}}"
            bindtap="selectCustomIcon" data-idx="{{idx}}">
            <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src(item)}}" mode="aspectFit" />
          </view>
        </view>
      </scroll-view>

      <text class="font-bold" style="margin-top:32rpx;font-size:28rpx;">{{i18n.select_color}}</text>
      <view class="flex-row gap-md flex-wrap" style="margin-top:16rpx;">
        <view wx:for="{{colorOptions}}" wx:key="*this"
          class="color-dot {{customColor === item ? 'color-dot-active' : ''}}"
          style="background:{{item}};"
          bindtap="selectCustomColor" data-color="{{item}}">
        </view>
      </view>

      <view class="flex-row gap-md" style="margin-top:48rpx;">
        <button class="btn-secondary flex-1" bindtap="closeCustomModal">{{i18n.cancel}}</button>
        <button class="btn-primary flex-1" bindtap="saveCustomAction">{{i18n.save}}</button>
      </view>
    </view>
  </view>

  <!-- Weight Modal -->
  <view wx:if="{{showWeightModal}}" class="modal-overlay" catchtap="closeWeightModal">
    <view class="modal-content card" catchtap="noop">
      <text class="h3">{{i18n.log_weight}}</text>
      <view class="flex-row gap-lg align-center" style="margin:40rpx 0;">
        <slider min="5" max="300" value="{{newWeight * 10}}" bindchange="onWeightSliderChange" activeColor="#FF7B54" style="flex:1;" />
        <view class="flex-row align-center" style="background:#FFF3E0; border-radius:16rpx; padding:12rpx 24rpx; width:180rpx; box-sizing:border-box;">
          <input type="digit" value="{{newWeight}}" bindinput="onWeightInput" style="flex:1; text-align:right; font-weight:bold; font-size:32rpx; color:#4A403A;" />
          <text class="font-bold" style="margin-left:8rpx; font-size:28rpx; color:#8F8377;">kg</text>
        </view>
      </view>
      <view class="flex-row gap-md" style="margin-top:48rpx;">
        <button class="btn-secondary flex-1" bindtap="closeWeightModal">{{i18n.cancel}}</button>
        <button class="btn-primary flex-1" bindtap="saveWeight">{{i18n.save}}</button>
      </view>
    </view>
  </view>

  <!-- Export Loading Overlay -->
  <view wx:if="{{exportGenerating}}" class="modal-overlay">
    <view style="background:#fff;border-radius:40rpx;padding:60rpx 80rpx;display:flex;flex-direction:column;align-items:center;gap:32rpx;">
      <text style="font-size:36rpx;font-weight:700;color:#2C2C2C;">{{i18n.exporting || '生成中...'}}</text>
      <text style="font-size:24rpx;color:#8A8A8A;">正在绘制您的专属报告</text>
    </view>
  </view>

  <!-- Export Preview Modal -->
  <view wx:if="{{showExportModal}}" class="modal-overlay" style="flex-direction:column;background:rgba(0,0,0,0.85);z-index:2000;" catchtap="closeExportModal">
    <!-- Scrollable Image Area -->
    <scroll-view scroll-y="true" style="width:100%; flex:1; height: 0;" catchtap="closeExportModal">
      <view style="padding:60rpx 40rpx 200rpx; display:flex; flex-direction:column; align-items:center;">
        <image
          wx:if="{{exportImageUrl}}"
          src="{{exportImageUrl}}"
          style="width:100%; border-radius:32rpx; box-shadow:0 40rpx 100rpx rgba(0,0,0,0.6);"
          mode="widthFix"
          catchtap="previewExportImage"
        />
        <text style="color:#FFF; font-size:24rpx; margin-top:32rpx; opacity:0.6;">{{i18n.export_success || '此图已保存至临时预览，点击可全屏查看'}}</text>
      </view>
    </scroll-view>

    <!-- Bottom Action Bar -->
    <view class="safe-bottom" style="width:100%; background:#FFFFFF; border-top-left-radius:56rpx; border-top-right-radius:56rpx; padding:40rpx 40rpx 64rpx; box-sizing:border-box; box-shadow:0 -20rpx 60rpx rgba(0,0,0,0.1);" catchtap="noop">
      <view style="width:80rpx; height:8rpx; background:#E5E5EA; border-radius:8rpx; margin:0 auto 32rpx;" />
      
      <view class="flex-row gap-md">
        <button class="btn-secondary flex-1" style="border-radius:32rpx; border:4rpx solid #F0EDE6; padding:24rpx 0;" bindtap="closeExportModal">{{i18n.done || '关闭'}}</button>
        <button class="btn-primary flex-2" style="border-radius:32rpx; padding:32rpx 0; background:var(--primary); color:#4A403A;" bindtap="saveExportImage">
          <image class="icon-img" style="width:32rpx;height:32rpx;" src="{{ic.src('Check')}}" mode="aspectFit" />
          <text>保存到相册</text>
        </button>
      </view>
    </view>
  </view>

  <!-- Hidden canvas for export (off-screen) -->
  <canvas
    type="2d"
    id="exportCanvas"
    style="position:fixed;left:-99999px;top:0;width:750px;height:1860px;"
  />
</view>
