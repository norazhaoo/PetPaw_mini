/* pages/dashboard/dashboard.wxss */

/* Unified section layout */
.section-block {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Pill scroll shared by Stock Alert and Things to Track */
.pill-scroll {
  white-space: nowrap;
}

.pill-row {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 8rpx;
  padding-top: 10rpx;
}

/* Each pill: icon circle + value + label stacked vertically */
.pill-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  min-width: 112rpx;
}

.pill-item-wrap {
  display: inline-flex;
  position: relative;
  flex-shrink: 0;
}

.pill-item-wrap.dragging {
  z-index: 3;
}

.pill-item-wrap.dragging .pill-item {
  transform: scale(1.06);
  opacity: 0.88;
}

.pill-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0EDE6;
}

.pill-value {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-main);
  line-height: 1;
  height: 34rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 140rpx;
  display: flex;
  align-items: center;
}

.pill-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-muted);
  white-space: nowrap;
}

.pill-delete-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  background: transparent;
}

.pill-item.hidden-item {
  opacity: 0.4;
  filter: grayscale(1);
}

.pill-delete-btn.hidden-item {
  background: rgba(0,0,0,0.1);
}

/* iOS Wiggle / Shake animation for edit mode */
@keyframes wiggle {
  0% { transform: rotate(-1.5deg); }
  50% { transform: rotate(1.5deg); }
  100% { transform: rotate(-1.5deg); }
}

.edit-mode .pill-icon-wrap {
  animation: wiggle 0.25s infinite ease-in-out;
  border: 2rpx solid var(--primary);
}

/* Calendar */
.today-btn {
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  background: var(--primary);
  color: var(--text-main);
  font-weight: 700;
  font-size: 22rpx;
}

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  text-align: center;
}

.cal-header {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-muted);
}

.cal-weekday {
  text-align: center;
}

.cal-cell {
  min-height: 96rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  border: 4rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cal-selected {
  border-color: var(--primary);
}

.cal-today {
  background: #FFFDF2;
}

.cal-day-num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
}

.cal-today-num {
  color: var(--warning);
  font-weight: 900;
}

.cal-icons {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx;
  justify-content: center;
  margin-top: 8rpx;
}

.cal-icon-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Stats */
.stat-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F0EDE6;
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
}

.stat-icon-wrap {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Log items */
.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
}

.log-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* Modal extras */
.icon-select-btn {
  border: 4rpx solid transparent;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #F0EDE6;
  flex-shrink: 0;
}

.icon-select-active {
  border-color: var(--text-main);
}

.color-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.color-dot-active {
  border-color: var(--text-main);
}
