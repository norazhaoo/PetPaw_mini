/* pages/dashboard/dashboard.wxss */

/* Unified section layout */
.section-block {
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Pill scroll shared by Stock Alert and Things to Track */
.pill-scroll {
  white-space: nowrap;
}

.pill-row {
  display: inline-flex;
  gap: 24rpx;
  padding-bottom: 8rpx;
  padding-top: 10rpx;
}

/* Each pill: icon circle + value + label stacked vertically */
.pill-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  min-width: 112rpx;
}

.pill-item-wrap {
  display: inline-flex;
  position: relative;
  flex-shrink: 0;
}

.pill-item-wrap.dragging {
  z-index: 3;
}

.pill-item-wrap.dragging .pill-item {
  transform: scale(1.06);
  opacity: 0.88;
}

.pill-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0EDE6;
}

.pill-value {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text-main);
  line-height: 1;
  height: 34rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 140rpx;
  display: flex;
  align-items: center;
}

.pill-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-muted);
  white-space: nowrap;
}

.pill-delete-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  background: transparent;
}

.pill-item.hidden-item {
  opacity: 0.4;
  filter: grayscale(1);
}

.pill-delete-btn.hidden-item {
  background: rgba(0,0,0,0.1);
}

/* iOS Wiggle / Shake animation for edit mode */
@keyframes wiggle {
  0% { transform: rotate(-1.5deg); }
  50% { transform: rotate(1.5deg); }
  100% { transform: rotate(-1.5deg); }
}

.edit-mode .pill-icon-wrap {
  animation: wiggle 0.25s infinite ease-in-out;
  border: 2rpx solid var(--primary);
}

/* Today records */
.today-log-card {
  gap: 24rpx;
}

.today-log-title {
  font-size: 32rpx;
  margin: 0;
}

.today-empty {
  min-height: 180rpx;
  border-radius: 28rpx;
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Monthly poster CTA */
.monthly-poster-card {
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
}

.poster-card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: rgba(254, 225, 64, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.poster-card-title {
  font-size: 30rpx;
  font-weight: 900;
  color: var(--text-main);
}

.poster-card-subtitle {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.poster-card-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: var(--text-main);
  font-size: 24rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.export-preview-overlay {
  flex-direction: column;
  background: rgba(0, 0, 0, 0.85);
  z-index: 2000;
}

.export-preview-scroll {
  width: 100%;
  flex: 1;
  height: 0;
}

.export-preview-content {
  padding: 60rpx 40rpx calc(160rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.export-preview-image {
  width: 100%;
  border-radius: 32rpx;
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.6);
}

.export-preview-tip {
  color: #FFFFFF;
  font-size: 24rpx;
  margin-top: 32rpx;
  opacity: 0.6;
}

/* Calendar */
.today-btn {
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  background: var(--primary);
  color: var(--text-main);
  font-weight: 700;
  font-size: 22rpx;
}

.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  text-align: center;
}

.cal-header {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-muted);
}

.cal-weekday {
  text-align: center;
}

.cal-cell {
  min-height: 80rpx;
  padding: 6rpx;
  border-radius: 20rpx;
  border: 4rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cal-selected {
  border-color: var(--primary);
}

.cal-today {
  background: #FFFDF2;
}

.cal-day-num {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
}

.cal-today-num {
  color: var(--warning);
  font-weight: 900;
}

.cal-icons {
  display: flex;
  flex-wrap: nowrap;
  justify-content: center;
  margin-top: 4rpx;
  min-height: 22rpx;
  width: 100%;
  overflow: hidden;
}

.cal-icon-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 7rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 0 0 2rpx #fff;
}

.cal-icon-dot + .cal-icon-dot {
  margin-left: -6rpx;
}

/* Stats */
.stat-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F0EDE6;
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
}

.stat-icon-wrap {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Log items */
.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--bg-color);
  border-radius: 16rpx;
}

.log-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* Modal extras */
.icon-select-btn {
  border: 4rpx solid transparent;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #F0EDE6;
  flex-shrink: 0;
}

.icon-select-active {
  border-color: var(--text-main);
}

.color-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.color-dot-active {
  border-color: var(--text-main);
}

.stats-rule-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F0EDE6;
  color: var(--text-main);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.stats-rules-overlay {
  z-index: 2500;
}

.stats-rules-card {
  gap: 28rpx;
}

.stats-rule-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F0EDE6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 40rpx;
  line-height: 1;
}

.stats-rule-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  line-height: 1.55;
}
