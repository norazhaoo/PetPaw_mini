<!-- pages/medical/medical.wxml -->
<wxs src="../../utils/icons.wxs" module="ic" />

<view class="app-container">
  <!-- Input Card -->
  <view class="card">
    <view class="flex-row gap-md">
      <image class="icon-img" lazy-load style="width:48rpx;height:48rpx;" src="{{ic.src('Stethoscope')}}" mode="aspectFit" />
      <text class="h2">{{i18n.medical_log}}</text>
    </view>

    <view class="card" style="background:var(--bg-color);box-shadow:none;">
      <text class="h3">{{i18n.symptoms}}</text>

      <!-- Symptom Grid: 3-column layout -->
      <view class="symptom-grid">
        <view wx:for="{{symptoms}}" wx:key="id"
          class="symptom-tag {{selectedSymptoms.indexOf(item.id) > -1 ? 'symptom-tag-active' : ''}}"
          bindtap="toggleSymptom" data-id="{{item.id}}">
          <view class="symptom-icon-wrap">
            <image class="icon-img" lazy-load src="{{ic.src(item.icon)}}" mode="aspectFit" />
          </view>
          <text class="symptom-label">{{item.label}}</text>
        </view>
      </view>

      <!-- Photo -->
      <view wx:if="{{image}}" class="photo-preview" bindtap="chooseImage">
        <image src="{{image}}" mode="aspectFill" class="photo-img" />
        <view class="photo-change-overlay">
          <image class="icon-img" lazy-load style="width:32rpx;height:32rpx;" src="{{ic.src('Camera')}}" mode="aspectFit" />
        </view>
        <view class="photo-remove" catchtap="removeImage">×</view>
      </view>
      <view wx:else class="photo-placeholder" bindtap="chooseImage">
        <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;" src="{{ic.src('Camera')}}" mode="aspectFit" />
        <text style="font-size:24rpx;font-weight:700;color:var(--text-muted);">{{i18n.photo}}</text>
      </view>

      <!-- Save button (own row) -->
      <view class="save-row">
        <button class="btn-primary" bindtap="handleSave"
          disabled="{{selectedSymptoms.length === 0 && !image}}">
          <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;" src="{{ic.src('Check')}}" mode="aspectFit" />
          {{i18n.add_record}}
        </button>
      </view>
    </view>
  </view>

  <!-- Records List -->
  <view class="card">
    <text class="h3">{{i18n.medical_log}}</text>

    <view wx:if="{{medicalRecords.length === 0}}" class="text-center" style="padding:80rpx;">
      <image class="icon-img" lazy-load style="width:96rpx;height:96rpx;" src="{{ic.src('FileText')}}" mode="aspectFit" />
      <text class="text-muted" style="display:block;margin-top:32rpx;">{{i18n.no_records_yet}}</text>
    </view>

    <view wx:else class="flex-col gap-lg">
      <view wx:for="{{medicalRecords}}" wx:key="id" class="record-card">
        <view class="record-delete" bindtap="deleteRecord" data-id="{{item.id}}">
          <image class="icon-img" lazy-load style="width:36rpx;height:36rpx;" src="{{ic.src('XCircle')}}" mode="aspectFit" />
        </view>
        <text class="text-muted" style="font-size:24rpx;margin-bottom:16rpx;">{{item.dateFormatted}}</text>
        <view class="record-tags-wrap">
          <view wx:for="{{item.tagDetails}}" wx:for-item="tag" wx:key="id" class="record-tag">
            <image class="icon-img" lazy-load src="{{ic.src(tag.icon)}}" mode="aspectFit" />
            <text>{{tag.label}}</text>
          </view>
        </view>
        <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" class="record-image" />
      </view>
    </view>
  </view>
</view>
