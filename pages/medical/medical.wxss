/* pages/medical/medical.wxss */

.photo-preview {
  position: relative;
  flex: 1;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.photo-placeholder {
  flex: 1;
  height: 200rpx;
  border: 4rpx dashed #E0DACA;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.record-card {
  position: relative;
  padding: 24rpx;
  border: 2rpx solid #F0EDE6;
  border-radius: 24rpx;
}

.record-delete {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
}

.record-tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
}

.record-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}
