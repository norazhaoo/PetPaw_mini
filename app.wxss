/* app.wxss - 全局样式 (对应 index.css) */

page {
  --primary: #FEE140;
  --primary-hover: #FCDC2A;
  --bg-color: #FFF3E0;
  --text-main: #4A403A;
  --text-muted: #8F8377;
  --warning: #FF7B54;
  --success: #93C653;
  --card-bg: #FFFFFF;
  --radius-lg: 48rpx;
  --radius-md: 32rpx;
  --radius-sm: 24rpx;
  --shadow-soft: 0 16rpx 48rpx rgba(235, 215, 170, 0.4);
  --shadow-button: 0 8rpx 24rpx rgba(254, 225, 64, 0.5);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-main);
  line-height: 1.5;
  box-sizing: border-box;
  font-size: 28rpx;
}

/* ===== Layout ===== */
.app-container {
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding-bottom: 200rpx;
}

/* ===== Typography ===== */
.h1 { font-size: 56rpx; font-weight: 800; color: var(--text-main); }
.h2 { font-size: 40rpx; font-weight: 700; color: var(--text-main); }
.h3 { font-size: 32rpx; font-weight: 700; color: var(--text-main); }
.text-muted { color: var(--text-muted); font-size: 28rpx; }
.font-bold { font-weight: 700; }
.text-center { text-align: center; }

/* ===== Card ===== */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-soft);
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* ===== Buttons ===== */
.btn-primary {
  background: var(--primary);
  color: var(--text-main);
  font-weight: 800;
  font-size: 32rpx;
  padding: 32rpx 48rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-button);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
}

.btn-primary::after { border: none; }

.btn-primary[disabled] {
  opacity: 0.5;
  color: var(--text-muted);
}

.btn-secondary {
  background: var(--card-bg);
  color: var(--text-main);
  border: 4rpx solid var(--primary);
  font-weight: 700;
  padding: 24rpx 40rpx;
  border-radius: var(--radius-md);
}

.btn-secondary::after { border: none; }

/* ===== Form ===== */
.input-field {
  width: 100%;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid #E0DACA;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-main);
  background: #fff;
}

/* ===== Overlay ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 90%;
  max-width: 700rpx;
}

/* ===== Tag ===== */
.tag {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: 2rpx solid #E0DACA;
  background: var(--card-bg);
}

.tag-active {
  background: var(--primary);
  border-color: var(--primary);
  box-shadow: var(--shadow-button);
}

/* ===== Dashed Button ===== */
.btn-dashed {
  background: transparent;
  border: 4rpx dashed var(--primary);
  padding: 32rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  width: 100%;
}

.btn-dashed::after { border: none; }

/* Header Card */
.header-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: var(--card-bg);
  padding: 32rpx 40rpx;
  border-radius: 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.06);
  border: 2rpx solid rgba(255,255,255,0.8);
}

.header-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #FFF;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.header-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, #FFB75E 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 6rpx solid #FFF;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

/* ===== Icon sizes ===== */
.icon-lg { width: 72rpx; height: 72rpx; }
.icon-md { width: 48rpx; height: 48rpx; }
.icon-sm { width: 28rpx; height: 28rpx; }

/* ===== Flex Utilities ===== */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }
.gap-sm { gap: 16rpx; }
.gap-md { gap: 24rpx; }
.gap-lg { gap: 32rpx; }

/* ===== Section Header ===== */
.section-title {
  font-size: 28rpx;
  color: var(--text-muted);
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  font-weight: 700;
}

/* Feedback toast */
.feedback-text {
  color: var(--success);
  font-weight: 700;
  font-size: 24rpx;
  text-align: center;
}

/* ===== Scrollbar hide ===== */
::-webkit-scrollbar {
  display: none;
}
